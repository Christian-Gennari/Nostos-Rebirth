{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BackupSettings": {
    "IsEnabled": false,
    "IntervalHours": 168,
    "Provider": "Local",
    "MaxBackups": 3,
    "IncludeBookFiles": true
  }
}